# FB Lead Bot - Variaveis de ambiente
# Copie para .env e preencha com seus dados

# Facebook credentials (usado pelo scraper via browser)
FB_EMAIL=
FB_PASSWORD=

# Database
DATABASE_URL=sqlite:///data/fbleadbot.db

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-to-a-random-secret

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/fbleadbot.log

# Export
EXPORT_DIR=exports
